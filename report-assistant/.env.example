# 登录密码
APP_PASSWORD=your_password_here

# 智谱AI知识库配置（用于文件管理）
ZHIPUAI_API_KEY=your_zhipuai_api_key
ZHIPUAI_KB_ID=your_knowledge_base_id
KNOWLEDGE_BASE_ID=
ZHIPUAI_BASE_URL=https://open.bigmodel.cn/api/llm

# 知乎开放平台API（用于联网搜索）
ZHIHU_ACCESS_SECRET=your_zhihu_access_secret

# 网页内容提取小模型配置（可选，默认用GLM-4-Flash via Zhipu）
# 未配置时仅用搜索摘要
EXTRACT_MODEL=GLM-4-Flash
EXTRACT_API_KEY=
EXTRACT_BASE_URL=https://open.bigmodel.cn/api/llm

# DeepSeek API配置（智能对话核心）
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
