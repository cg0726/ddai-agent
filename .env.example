# ===========================================
# 尽责报告助手 - 环境变量配置模板
# 使用前请复制为 .env 并修改各项值
# ===========================================

# ---- 登录密码 ----
# ⚠️ 部署前务必修改默认值！生产环境请使用强密码
APP_PASSWORD=your_password_here

# ---- 智谱AI 知识库配置（文件管理） ----
ZHIPUAI_API_KEY=your_zhipuai_api_key
KNOWLEDGE_BASE_ID=your_knowledge_base_id
# 智谱AI 知识库应用API地址（通常无需修改）
ZHIPUAI_KB_BASE_URL=https://open.bigmodel.cn/api/llm-application

# ---- 知乎开放平台 API（联网搜索） ----
ZHIHU_ACCESS_SECRET=your_zhihu_access_secret

# ---- 网页内容提取小模型配置（可选） ----
# 用于提取搜索结果的详细内容，未配置时仅显示搜索摘要
# 代码默认值: deepseek-v4-flash
EXTRACT_MODEL=GLM-4-Flash
EXTRACT_API_KEY=
EXTRACT_BASE_URL=https://open.bigmodel.cn/api/llm

# ---- DeepSeek API 配置（智能对话核心） ----
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
